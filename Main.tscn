[sub_resource type="GDScript" id="GDScript_kek77"]
resource_name = "halo_tracker"
script/source = "extends Node3D

@export var camera: XRCamera3D 
@export var float_height: float = 0.3
@export var follow_speed: float = 16.0

func _process(delta: float) -> void:
	if camera:
		var target_position = camera.global_position + Vector3(0, float_height, 0)
		var target_y_rotation = camera.global_rotation.y
		
		global_position = target_position
		global_rotation.y = lerp_angle(global_rotation.y, target_y_rotation, follow_speed * delta)
"

