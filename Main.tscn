[sub_resource type="Shader" id="Shader_vivmo"]
code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, cull_back;

// --- BASE COLOR ---
uniform vec4 albedo : source_color = vec4(0.4, 0.8, 0.3, 1.0); // Vibrant Zelda Green
uniform sampler2D texture_albedo : source_color, filter_linear_mipmap, repeat_enable;

// --- SMART POSTERIZATION ---
// Crushes the messy grass blades into painted, stylized chunks
uniform bool use_posterization = true;
uniform float color_steps : hint_range(1.0, 16.0, 1.0) = 3.0; 
uniform float black_level_lift : hint_range(0.0, 1.0, 0.01) = 0.15; 

// --- NORMAL & AO MAPS ---
uniform sampler2D texture_normal : hint_normal, filter_linear_mipmap, repeat_enable;
uniform float normal_scale : hint_range(-16.0, 16.0) = 1.0;

uniform sampler2D texture_ambient_occlusion : hint_default_white, filter_linear_mipmap, repeat_enable;
uniform float ao_strength : hint_range(0.0, 1.0, 0.01) = 1.0;

// --- CEL SHADING SHADOWS ---
uniform vec4 shadow_color : source_color = vec4(0.1, 0.35, 0.25, 1.0); // Deep, cool forest green
uniform float shadow_threshold : hint_range(-1.0, 1.0, 0.01) = 0.0;
uniform float shadow_softness : hint_range(0.0, 1.0, 0.01) = 0.02; // Tiny bit of softness for organic grass

// --- TRIPLANAR MAPPING SETUP ---
varying vec3 uv1_triplanar_pos;
uniform float uv1_blend_sharpness : hint_range(0.0, 150.0, 0.001) = 1.0;
varying vec3 uv1_power_normal;

uniform vec3 uv1_scale = vec3(1.0, 1.0, 1.0);
uniform vec3 uv1_offset = vec3(0.0, 0.0, 0.0);

varying float toon_ao;

void vertex() {
    // Standard Godot Triplanar math (DO NOT TOUCH!)
    vec3 normal = MODEL_NORMAL_MATRIX * NORMAL;

    TANGENT = vec3(0.0, 0.0, -1.0) * abs(normal.x);
    TANGENT += vec3(1.0, 0.0, 0.0) * abs(normal.y);
    TANGENT += vec3(1.0, 0.0, 0.0) * abs(normal.z);
    TANGENT = inverse(MODEL_NORMAL_MATRIX) * normalize(TANGENT);

    BINORMAL = vec3(0.0, 1.0, 0.0) * abs(normal.x);
    BINORMAL += vec3(0.0, 0.0, -1.0) * abs(normal.y);
    BINORMAL += vec3(0.0, 1.0, 0.0) * abs(normal.z);
    BINORMAL = inverse(MODEL_NORMAL_MATRIX) * normalize(BINORMAL);

    uv1_power_normal = pow(abs(normal), vec3(uv1_blend_sharpness));
    uv1_triplanar_pos = (MODEL_MATRIX * vec4(VERTEX, 1.0)).xyz * uv1_scale + uv1_offset;
    uv1_power_normal /= dot(uv1_power_normal, vec3(1.0));
    uv1_triplanar_pos *= vec3(1.0, -1.0, 1.0);
}

// Reusable function to sample textures from all 3 axes
vec4 triplanar_texture(sampler2D p_sampler, vec3 p_weights, vec3 p_triplanar_pos) {
    vec4 samp = vec4(0.0);
    samp += texture(p_sampler, p_triplanar_pos.xy) * p_weights.z;
    samp += texture(p_sampler, p_triplanar_pos.xz) * p_weights.y;
    samp += texture(p_sampler, p_triplanar_pos.zy * vec2(-1.0, 1.0)) * p_weights.x;
    return samp;
}

void fragment() {
    // 1. Triplanar Albedo
    // Notice we use the custom function instead of texture()
    vec4 albedo_tex = triplanar_texture(texture_albedo, uv1_power_normal, uv1_triplanar_pos);
    vec3 final_color = albedo_tex.rgb;

    // --- APPLY SMART POSTERIZATION ---
    if (use_posterization) {
        final_color = final_color + vec3(black_level_lift) * (1.0 - final_color);
        float luminance = dot(final_color, vec3(0.299, 0.587, 0.114));
        float stepped_luminance = floor(luminance * color_steps) / color_steps;
        stepped_luminance = max(stepped_luminance, 0.1);
        final_color = final_color * (stepped_luminance / max(luminance, 0.0001));
    }

    ALBEDO = albedo.rgb * final_color;

    // 2. Triplanar Normal Map
    NORMAL_MAP = triplanar_texture(texture_normal, uv1_power_normal, uv1_triplanar_pos).rgb;
    NORMAL_MAP_DEPTH = normal_scale;

    // 3. Triplanar AO Map
    float ao_tex = triplanar_texture(texture_ambient_occlusion, uv1_power_normal, uv1_triplanar_pos).r;
    toon_ao = mix(1.0, ao_tex, ao_strength);
}

void light() {
    float NdotL = dot(NORMAL, LIGHT);

    float light_intensity = smoothstep(shadow_threshold - shadow_softness, shadow_threshold + shadow_softness, NdotL);
    float toon_attenuation = step(0.5, ATTENUATION);

    float final_light = light_intensity * toon_attenuation * toon_ao;

    vec3 diffuse = mix(shadow_color.rgb * ALBEDO, ALBEDO, final_light);

    DIFFUSE_LIGHT += diffuse * LIGHT_COLOR;
}"

