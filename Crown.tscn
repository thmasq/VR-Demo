[sub_resource type="Shader" id="Shader_jgb2w"]
code = "shader_type spatial;
// Removed diffuse_burley and specular_schlick_ggx. We handle light manually.
render_mode blend_mix, depth_draw_opaque, cull_back;

// --- BASE COLOR ---
uniform vec4 albedo : source_color = vec4(0.1, 0.8, 0.4, 1.0); // Emerald Green
uniform sampler2D texture_albedo : source_color, filter_linear_mipmap, repeat_enable;

// --- CEL SHADING SHADOWS ---
uniform vec4 shadow_color : source_color = vec4(0.0, 0.3, 0.2, 1.0); // Deep Teal/Forest Green
uniform float shadow_threshold : hint_range(-1.0, 1.0, 0.01) = 0.0;
// Make softness extremely low (0.001) for the hard, rigid cuts of a crystal
uniform float shadow_softness : hint_range(0.0, 1.0, 0.001) = 0.001; 

// --- CRYSTAL GLINT (SPECULAR) ---
uniform vec4 specular_color : source_color = vec4(1.0, 1.0, 1.0, 1.0);
uniform float specular_threshold : hint_range(0.0, 1.0, 0.01) = 0.98; // Very high for a tiny, sharp glint
uniform float specular_softness : hint_range(0.0, 1.0, 0.001) = 0.001;

// --- UV CONTROLS ---
uniform vec3 uv1_scale = vec3(1.0);
uniform vec3 uv1_offset = vec3(0.0);

void vertex() {
	UV = UV * uv1_scale.xy + uv1_offset.xy;
}

void fragment() {
	vec2 base_uv = UV;
	vec4 albedo_tex = texture(texture_albedo, base_uv);
	
	ALBEDO = albedo.rgb * albedo_tex.rgb;
    
    // Notice how all the Metallic and Roughness texture sampling is gone.
    // We don't need it for a cartoon jewel!
}

void light() {
	// 1. Calculate light direction
	float NdotL = dot(NORMAL, LIGHT);

	// 2. Hard cut for the shadow (rigid for crystals)
	float light_intensity = smoothstep(shadow_threshold - shadow_softness, shadow_threshold + shadow_softness, NdotL);

	// 3. Tinted shadow mix
	vec3 diffuse = mix(shadow_color.rgb * ALBEDO, ALBEDO, light_intensity);

	// 4. The Crystal Glint (Specular)
	vec3 half_vector = normalize(VIEW + LIGHT);
	float NdotH = dot(NORMAL, half_vector);
	
	float spec_intensity = smoothstep(specular_threshold - specular_softness, specular_threshold + specular_softness, NdotH);
	spec_intensity *= light_intensity; // Glint only appears in the light

	// 5. Output
	DIFFUSE_LIGHT += diffuse * LIGHT_COLOR * ATTENUATION;
	SPECULAR_LIGHT += spec_intensity * specular_color.rgb * LIGHT_COLOR * ATTENUATION;
}"

