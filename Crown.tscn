[sub_resource type="GDScript" id="GDScript_4c57u"]
script/source = "@tool
extends XRToolsPickable

@export var fade_duration: float = 3.0

@onready var audio_player: AudioStreamPlayer3D = $GameOverSound

var fade_tween: Tween
var fade_screen: MeshInstance3D
var game_is_over: bool = false
var game_over_text: Label3D

func _ready() -> void:
	super._ready() 
	
	dropped.connect(_on_crown_dropped)
	picked_up.connect(_on_crown_picked_up) 
	body_entered.connect(_on_crown_body_entered)
	
	var screens = get_tree().get_nodes_in_group(\"fade_screen\")
	if screens.size() > 0:
		fade_screen = screens[0]
		
	var texts = get_tree().get_nodes_in_group(\"game_over_text\")
	if texts.size() > 0:
		game_over_text = texts[0]

func _on_crown_dropped(_pickable: Variant) -> void:
	if game_is_over: return
	
	if fade_screen:
		if fade_tween:
			fade_tween.kill()
		
		fade_tween = create_tween()
		fade_tween.tween_property(
			fade_screen.get_active_material(0), 
			\"albedo_color:a\", 
			0.8, 
			fade_duration
		)

func _on_crown_picked_up(_pickable: Variant) -> void:
	if game_is_over: return
	
	if fade_screen:
		if fade_tween:
			fade_tween.kill()
		
		fade_screen.get_active_material(0).albedo_color.a = 0.0

func _on_crown_body_entered(body: Node) -> void:
	if game_is_over: return
	
	if is_picked_up():
		return
		
	var is_floor = body.is_in_group(\"floor\")
	if not is_floor and body.get_parent() != null:
		is_floor = body.get_parent().is_in_group(\"floor\")
		
	if is_floor:
		trigger_game_over()

func trigger_game_over() -> void:
	game_is_over = true
	
	if fade_tween:
		fade_tween.kill()
	
	if fade_screen:
		fade_screen.get_active_material(0).albedo_color.a = 1.0
		
	if audio_player:
		audio_player.play()
	
	if game_over_text:
		game_over_text.show()

	# Optional: Pause the game tree so nothing else moves
	# get_tree().paused = true
"

