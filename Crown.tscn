[sub_resource type="Shader" id="Shader_yd3dr"]
code = "shader_type spatial;
// Standard mix, backface culling, no PBR lighting models
render_mode blend_mix, depth_draw_opaque, cull_back;

// --- BASE COLOR ---
uniform vec4 albedo : source_color = vec4(0.6, 0.85, 0.95, 1.0); // Icy light blue
uniform sampler2D texture_albedo : source_color, filter_linear_mipmap, repeat_enable;

// --- CEL SHADING SHADOWS ---
uniform vec4 shadow_color : source_color = vec4(0.2, 0.4, 0.7, 1.0); // Deep frosty blue
uniform float shadow_threshold : hint_range(-1.0, 1.0, 0.01) = 0.0;
uniform float shadow_softness : hint_range(0.0, 1.0, 0.001) = 0.001; // Hard cuts for solid ice

// --- ICE GLINT (SPECULAR) ---
uniform vec4 specular_color : source_color = vec4(1.0, 1.0, 1.0, 1.0);
uniform float specular_threshold : hint_range(0.0, 1.0, 0.01) = 0.95; // Sharp glint
uniform float specular_softness : hint_range(0.0, 1.0, 0.001) = 0.001;

// --- FROST EDGE (RIM LIGHT) ---
uniform vec4 rim_color : source_color = vec4(0.8, 0.95, 1.0, 1.0); // Bright, almost white blue
uniform float rim_threshold : hint_range(0.0, 1.0, 0.01) = 0.65;
uniform float rim_softness : hint_range(0.0, 1.0, 0.01) = 0.05;

// --- UV CONTROLS ---
uniform vec3 uv1_scale = vec3(1.0);
uniform vec3 uv1_offset = vec3(0.0);

void vertex() {
	UV = UV * uv1_scale.xy + uv1_offset.xy;
}

void fragment() {
	vec2 base_uv = UV;
	vec4 albedo_tex = texture(texture_albedo, base_uv);
	
	ALBEDO = albedo.rgb * albedo_tex.rgb;
	ALPHA = albedo.a * albedo_tex.a;
}

void light() {
	// 1. Calculate basic light direction and shadow cut
	float NdotL = dot(NORMAL, LIGHT);
	float light_intensity = smoothstep(shadow_threshold - shadow_softness, shadow_threshold + shadow_softness, NdotL);
	
	// Mix base color with tinted shadow
	vec3 diffuse = mix(shadow_color.rgb * ALBEDO, ALBEDO, light_intensity);

	// 2. The Ice Glint (Specular)
	vec3 half_vector = normalize(VIEW + LIGHT);
	float NdotH = dot(NORMAL, half_vector);
	float spec_intensity = smoothstep(specular_threshold - specular_softness, specular_threshold + specular_softness, NdotH);
	spec_intensity *= light_intensity; // Glint only in the light

	// 3. The Frost Edge (Rim Light)
	// Calculate the angle between the camera view and the surface normal
	float VdotN = 1.0 - dot(VIEW, NORMAL);
	
	// Create a band of light around the grazing angles
	float rim_intensity = smoothstep(rim_threshold - rim_softness, rim_threshold + rim_softness, VdotN);
	
	// Multiply by light_intensity so the rim light doesn't glow artificially in the dark shadows
	rim_intensity *= light_intensity; 

	// 4. Output Final Light
	DIFFUSE_LIGHT += diffuse * LIGHT_COLOR * ATTENUATION;
	
	// Add both the sharp specular dot and the frosty rim light to the specular output
	SPECULAR_LIGHT += (spec_intensity * specular_color.rgb + rim_intensity * rim_color.rgb) * LIGHT_COLOR * ATTENUATION;
}"

