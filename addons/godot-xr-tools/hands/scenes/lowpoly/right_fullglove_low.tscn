[sub_resource type="Shader" id="Shader_n3wjh"]
code = "shader_type spatial;
// Removed PBR render modes. We just want a basic mix with back-culling.
render_mode blend_mix, depth_draw_opaque, cull_back;

// --- BASE PROPERTIES ---
uniform vec4 albedo : source_color = vec4(0.2, 0.8, 0.4, 1.0);
uniform sampler2D texture_albedo : source_color, filter_linear_mipmap, repeat_enable;

// --- CEL SHADING SHADOWS ---
uniform vec4 shadow_color : source_color = vec4(0.3, 0.3, 0.5, 1.0); 
uniform float shadow_threshold : hint_range(-1.0, 1.0, 0.01) = 0.0;
// Softness acts as anti-aliasing for the shadow edge. Keep it very low (0.01) for Wind Waker style.
uniform float shadow_softness : hint_range(0.0, 1.0, 0.01) = 0.01;

// --- SLIME SHINE (SPECULAR) ---
uniform vec4 specular_color : source_color = vec4(1.0, 1.0, 1.0, 1.0);
uniform float specular_threshold : hint_range(0.0, 1.0, 0.01) = 0.95; // High threshold = tiny, sharp dot
uniform float specular_softness : hint_range(0.0, 1.0, 0.01) = 0.01;

// --- UV CONTROLS ---
uniform vec3 uv1_scale = vec3(1.0);
uniform vec3 uv1_offset = vec3(0.0);

void vertex() {
    UV = UV * uv1_scale.xy + uv1_offset.xy;
}

void fragment() {
    vec2 base_uv = UV;
    vec4 albedo_tex = texture(texture_albedo, base_uv);
    
    // Pass the flat color to the light function
    ALBEDO = albedo.rgb * albedo_tex.rgb;
    ALPHA = albedo.a * albedo_tex.a;
}

void light() {
    // 1. Calculate the direction of the light hitting the surface (-1.0 to 1.0)
    float NdotL = dot(NORMAL, LIGHT);

    // 2. Create the hard shadow cut using smoothstep (softness prevents ugly jagged pixels)
    float light_intensity = smoothstep(shadow_threshold - shadow_softness, shadow_threshold + shadow_softness, NdotL);

    // 3. Mix the base color with the shadow color based on the cut
    // We multiply shadow_color by ALBEDO so the shadow naturally matches the slime's base color
    vec3 diffuse = mix(shadow_color.rgb * ALBEDO, ALBEDO, light_intensity);

    // 4. Calculate the shiny specular dot
    vec3 half_vector = normalize(VIEW + LIGHT);
    float NdotH = dot(NORMAL, half_vector);
    
    // Create a hard cut for the specular reflection
    float spec_intensity = smoothstep(specular_threshold - specular_softness, specular_threshold + specular_softness, NdotH);
    
    // Prevent the shiny dot from appearing inside the shaded/dark areas
    spec_intensity *= light_intensity;

    // 5. Output the final custom light
    DIFFUSE_LIGHT += diffuse * LIGHT_COLOR * ATTENUATION;
    SPECULAR_LIGHT += spec_intensity * specular_color.rgb * LIGHT_COLOR * ATTENUATION;
}"

