[sub_resource type="GDScript" id="GDScript_s6ur2"]
resource_name = "GeoSlime.gdscript"
script/source = "@tool
extends XRToolsPickable

@export_category(\"Invasion AI (Outside)\")
@export var speed: float = 3.0
@export var turn_speed: float = 10.0

@export_category(\"Jump AI Settings\")
@export var target: Node3D
@export var arc_height: float = 1.0
@export var telegraph_duration: float = 0.2
@export var steal_chance: float = 1.0

var is_guaranteed_miss: bool = false

enum State {
	IDLE,
	TELEGRAPHING,
	AIRBORNE,
	MOVING_TO_QUEUE,
	WAITING_IN_QUEUE,
	JUMPING_QUEUE
}
var current_state: State = State.IDLE

@onready var jump_timer: Timer = Timer.new()
@onready var doom_timer: Timer = Timer.new()
@onready var mesh: MeshInstance3D = $GeoSlimeMesh
@onready var snatch_area: Area3D = $SnatchArea
@onready var crown_holder: Marker3D = $CrownHolder
@onready var nav_agent: NavigationAgent3D = $NavigationAgent3D

var anim_tween: Tween
var base_mesh_scale: Vector3
var has_stolen_crown: bool = false
var stolen_crown: Node3D = null
var leap_start_pos: Vector3

var invasion_manager: InvasionManager
var target_marker: Marker3D = null

var jump_tween_h: Tween
var jump_tween_v: Tween
var is_jumping_to_wall: bool = false

func _ready() -> void:
	super._ready()

	if Engine.is_editor_hint(): return

	contact_monitor = true
	max_contacts_reported = 5

	base_mesh_scale = mesh.scale

	add_child(jump_timer)
	jump_timer.one_shot = true
	jump_timer.timeout.connect(_on_jump_timer_timeout)

	add_child(doom_timer)
	doom_timer.one_shot = true
	doom_timer.timeout.connect(_on_doom_timer_timeout)

	body_entered.connect(_on_body_entered)
	if snatch_area:
		snatch_area.body_entered.connect(_on_snatch_area_body_entered)

	if has_signal(\"picked_up\"):
		picked_up.connect(_on_picked_up)
	if has_signal(\"dropped\"):
		dropped.connect(_on_dropped)

	var test_timer = Timer.new()
	add_child(test_timer)
	test_timer.wait_time = 4.0
	test_timer.timeout.connect(start_telegraph)
	test_timer.start()

	nav_agent.velocity_computed.connect(_on_velocity_computed)

func _on_picked_up(_pickable) -> void:
	if jump_tween_h and jump_tween_h.is_valid(): jump_tween_h.kill()
	if jump_tween_v and jump_tween_v.is_valid(): jump_tween_v.kill()
	if anim_tween and anim_tween.is_valid(): anim_tween.kill()

func _on_dropped(_pickable) -> void:
	freeze = false

func _physics_process(delta: float) -> void:
	if is_picked_up():
		return

	if current_state == State.MOVING_TO_QUEUE:
		navigate_to_target(delta)

func start_queue_navigation_sequence() -> void:
	if not invasion_manager or current_state == State.MOVING_TO_QUEUE:
		return

	target_marker = invasion_manager.claim_closest_queue_spot(self)

	if target_marker:
		nav_agent.target_position = target_marker.global_position
		current_state = State.MOVING_TO_QUEUE
	else:
		current_state = State.IDLE
		get_tree().create_timer(1.5).timeout.connect(start_queue_navigation_sequence)

func navigate_to_target(_delta: float) -> void:
	if nav_agent.is_navigation_finished():
		current_state = State.WAITING_IN_QUEUE
		snap_to_queue_spot()
		check_queue_position()
		return

	var next_path_pos: Vector3 = nav_agent.get_next_path_position()
	var current_pos: Vector3 = global_position

	var direction: Vector3 = current_pos.direction_to(next_path_pos)
	direction.y = 0
	direction = direction.normalized()

	var desired_velocity: Vector3 = direction * speed
	
	if nav_agent.avoidance_enabled:
		nav_agent.set_velocity(desired_velocity)
	else:
		_on_velocity_computed(desired_velocity)

func _on_velocity_computed(safe_velocity: Vector3) -> void:
	if is_picked_up() or current_state != State.MOVING_TO_QUEUE:
		return

	linear_velocity = Vector3(safe_velocity.x, linear_velocity.y, safe_velocity.z)

	var direction = safe_velocity
	direction.y = 0
	direction = direction.normalized()

	if direction.length_squared() > 0.01:
		var visual_forward = -global_transform.basis.z
		var angle_diff = visual_forward.signed_angle_to(direction, Vector3.UP)
		angular_velocity.y = angle_diff * turn_speed

func snap_to_queue_spot() -> void:
	if not is_instance_valid(target_marker): return
	linear_velocity = Vector3.ZERO
	angular_velocity = Vector3.ZERO
	global_position = target_marker.global_position
	global_transform.basis = target_marker.global_transform.basis
	rotate_y(PI)

func check_queue_position() -> void:
	if not is_instance_valid(target_marker): return
	if target_marker.name == \"Spot1\":
		get_tree().create_timer(1.0).timeout.connect(climb_ladder)

func advance_to_spot(new_marker: Marker3D) -> void:
	if not is_inside_tree() or is_queued_for_deletion() or not is_instance_valid(new_marker):
		return

	target_marker = new_marker
	
	if current_state == State.WAITING_IN_QUEUE:
		perform_parabolic_jump(new_marker.global_position, 0.5, false)
	elif current_state == State.MOVING_TO_QUEUE:
		nav_agent.target_position = target_marker.global_position

func climb_ladder() -> void:
	if not is_instance_valid(target_marker) or not is_instance_valid(invasion_manager): return
	
	var queue_node = target_marker.get_parent()
	var ladder_node = queue_node.get_parent()
	var jump_to_marker = ladder_node.get_node_or_null(\"JumpTo\")
	
	if jump_to_marker:
		invasion_manager.release_claim(target_marker)
		target_marker = null
		perform_parabolic_jump(jump_to_marker.global_position, 1.0, true)

func perform_parabolic_jump(target_pos: Vector3, _duration: float, is_climbing_wall: bool) -> void:
	if is_picked_up():
		return

	current_state = State.JUMPING_QUEUE
	is_jumping_to_wall = is_climbing_wall
	
	freeze = false
	
	var direction = (target_pos - global_position)
	direction.y = 0
	if direction.length_squared() > 0.01:
		var target_rot_y = atan2(-direction.x, -direction.z)
		rotation.y = target_rot_y
	
	var impulse = _calculate_jump_impulse(target_pos, 0.8)
	
	linear_velocity = Vector3.ZERO
	angular_velocity = Vector3.ZERO
	apply_central_impulse(impulse * mass)

func _calculate_jump_impulse(target_pos: Vector3, added_height: float) -> Vector3:
	var gravity: float = ProjectSettings.get_setting(\"physics/3d/default_gravity\")
	var start_pos = global_position
	var peak_y = max(start_pos.y, target_pos.y) + added_height
	
	var displacement_y_up = peak_y - start_pos.y
	var velocity_y = sqrt(2.0 * gravity * displacement_y_up)
	
	var time_up = velocity_y / gravity
	var displacement_y_down = max(0.0, peak_y - target_pos.y)
	var time_down = sqrt(2.0 * displacement_y_down / gravity)
	var total_time = time_up + time_down
	
	var displacement_xz = Vector3(target_pos.x - start_pos.x, 0, target_pos.z - start_pos.z)
	var velocity_xz = displacement_xz / total_time
	
	return velocity_xz + Vector3(0, velocity_y, 0)

func _on_body_entered(body: Node) -> void:
	if current_state == State.JUMPING_QUEUE:
		if body.is_in_group(\"outside_floor\") or body.is_in_group(\"floor\"):
			if is_picked_up():
				return
				
			if is_jumping_to_wall:
				reset_to_idle()
			else:
				current_state = State.WAITING_IN_QUEUE
				snap_to_queue_spot()
				check_queue_position()
			return

	if current_state == State.WAITING_IN_QUEUE:
		return
		
	if body.is_in_group(\"outside_floor\"):
		if current_state == State.AIRBORNE:
			reset_to_idle()
			
		if current_state == State.IDLE:
			start_queue_navigation_sequence()

	elif body.is_in_group(\"floor\"):
		if current_state == State.MOVING_TO_QUEUE:
			if target_marker and invasion_manager:
				invasion_manager.release_claim(target_marker)
				target_marker = null
			reset_to_idle()
			
		elif current_state == State.AIRBORNE:
			reset_to_idle()

func reset_to_idle() -> void:
	current_state = State.IDLE
	freeze = false
	linear_velocity = Vector3.ZERO
	if mesh:
		if anim_tween:
			anim_tween.kill()
		mesh.scale = base_mesh_scale

func start_telegraph() -> void:
	if current_state != State.IDLE or not target: return

	var is_on_valid_floor = false
	for body in get_colliding_bodies():
		if body.is_in_group(\"floor\"):
			is_on_valid_floor = true
			break

	if not is_on_valid_floor:
		return

	current_state = State.TELEGRAPHING

	var target_pos = target.global_position
	target_pos.y = mesh.global_position.y

	var flipped_target = mesh.global_position + (mesh.global_position - target_pos)

	mesh.look_at(flipped_target, Vector3.UP)

	if anim_tween:
		anim_tween.kill()
	anim_tween = create_tween()

	var squash_scale = base_mesh_scale * Vector3(1.4, 0.6, 1.4)
	anim_tween.tween_property(mesh, \"scale\", squash_scale, telegraph_duration).set_trans(Tween.TRANS_SINE)

	jump_timer.start(telegraph_duration)

func _on_jump_timer_timeout() -> void:
	leap_at_target()

func leap_at_target() -> void:
	current_state = State.AIRBORNE

	var gravity: float = ProjectSettings.get_setting(\"physics/3d/default_gravity\")
	var start_pos = global_position
	leap_start_pos = start_pos

	var end_pos = target.global_position

	is_guaranteed_miss = randf() > steal_chance

	if is_guaranteed_miss:
		var miss_direction = 1 if randf() > 0.5 else -1
		var right_vector = target.global_transform.basis.x.normalized()
		end_pos += right_vector * (1.5 * miss_direction)

	var peak_y = max(start_pos.y, end_pos.y) + arc_height
	var displacement_y_up = peak_y - start_pos.y

	var velocity_y = sqrt(2.0 * gravity * displacement_y_up)
	var time_up = velocity_y / gravity
	var displacement_y_down = max(0.0, peak_y - end_pos.y)
	var time_down = sqrt(2.0 * displacement_y_down / gravity)
	var total_time = time_up + time_down

	var displacement_xz = Vector3(end_pos.x - start_pos.x, 0, end_pos.z - start_pos.z)
	var velocity_xz = displacement_xz / total_time

	var impulse_vector = velocity_xz + Vector3(0, velocity_y, 0)

	linear_velocity = Vector3.ZERO
	apply_central_impulse(impulse_vector * mass)

	if anim_tween:
		anim_tween.kill()
	anim_tween = create_tween()

	var stretch_scale = base_mesh_scale * Vector3(0.7, 1.5, 0.7)
	anim_tween.tween_property(mesh, \"scale\", stretch_scale, 0.1).set_trans(Tween.TRANS_SINE)
	anim_tween.tween_property(mesh, \"scale\", base_mesh_scale, 0.2).set_trans(Tween.TRANS_SINE)

func _on_snatch_area_body_entered(body: Node) -> void:
	if current_state != State.AIRBORNE or has_stolen_crown: return
	if is_guaranteed_miss: return

	if body.is_in_group(\"headwear\"):
		call_deferred(\"steal_crown\", body)

func steal_crown(crown: Node3D) -> void:
	has_stolen_crown = true
	stolen_crown = crown

	set_collision_mask_value(1, true)

	if \"enabled\" in crown:
		crown.set(\"enabled\", false)

	if crown.has_method(\"is_picked_up\") and crown.is_picked_up():
		var holder = null
		if crown.has_method(\"get_picked_up_by\"):
			holder = crown.get_picked_up_by()
		else:
			holder = crown.get(\"picked_up_by\")

		if holder and holder.has_method(\"drop_object\"):
			var holder_was_enabled = false
			if \"enabled\" in holder:
				holder_was_enabled = holder.get(\"enabled\")
				holder.set(\"enabled\", false)

			holder.drop_object()

			if \"enabled\" in holder:
				holder.set(\"enabled\", holder_was_enabled)

	if crown is RigidBody3D:
		crown.freeze = true

	for child in crown.get_children():
		if child is CollisionShape3D:
			child.set_deferred(\"disabled\", true)

	if crown.get_parent():
		crown.reparent(crown_holder, false)

	crown.global_transform = crown_holder.global_transform

	doom_timer.start(3.0)
	ninja_jump_away()

func ninja_jump_away() -> void:
	linear_velocity = Vector3.ZERO
	angular_velocity = Vector3.ZERO

	var gravity: float = ProjectSettings.get_setting(\"physics/3d/default_gravity\")
	var start_pos = global_position

	var dir_from_target = (leap_start_pos - target.global_position)
	dir_from_target.y = 0
	dir_from_target = dir_from_target.normalized()

	var end_pos = target.global_position + (dir_from_target * 1.0)
	var ninja_arc = arc_height * 1.0
	var peak_y = max(start_pos.y, end_pos.y) + ninja_arc

	var displacement_y_up = peak_y - start_pos.y
	var velocity_y = sqrt(2.0 * gravity * displacement_y_up)

	var time_up = velocity_y / gravity
	var displacement_y_down = max(0.0, peak_y - end_pos.y)
	var time_down = sqrt(2.0 * displacement_y_down / gravity)
	var total_time = time_up + time_down

	var displacement_xz = Vector3(end_pos.x - start_pos.x, 0, end_pos.z - start_pos.z)
	var velocity_xz = displacement_xz / total_time

	var impulse_vector = velocity_xz + Vector3(0, velocity_y, 0)
	apply_central_impulse(impulse_vector * mass)

func _on_doom_timer_timeout() -> void:
	if not has_stolen_crown or not stolen_crown:
		melt_away()
		return

	set_collision_mask_value(1, false)

	var main_world = get_tree().current_scene
	stolen_crown.reparent(main_world, true)

	if stolen_crown is RigidBody3D:
		stolen_crown.freeze = false
		var toss_impulse = Vector3(0, 12.0, 0) * stolen_crown.mass
		stolen_crown.apply_central_impulse(toss_impulse)

		stolen_crown.angular_velocity = Vector3(
			randf_range(-4, 4),
			randf_range(-4, 4),
			randf_range(-4, 4)
		)

	for child in stolen_crown.get_children():
		if child is CollisionShape3D:
			child.set_deferred(\"disabled\", false)

	if \"enabled\" in stolen_crown:
		stolen_crown.enabled = true

	has_stolen_crown = false
	stolen_crown = null

	melt_away()

func melt_away() -> void:
	freeze = true
	collision_layer = 0
	collision_mask = 0

	if snatch_area:
		snatch_area.set_deferred(\"monitoring\", false)

	current_state = State.IDLE

	if anim_tween:
		anim_tween.kill()
	anim_tween = create_tween()

	var puddle_scale = Vector3(base_mesh_scale.x * 1.5, 0.05, base_mesh_scale.z * 1.5)
	anim_tween.tween_property(mesh, \"scale\", puddle_scale, 0.4).set_trans(Tween.TRANS_CUBIC).set_ease(Tween.EASE_IN)
	anim_tween.finished.connect(queue_free)

func _exit_tree() -> void:
	if target_marker and invasion_manager:
		invasion_manager.release_claim(target_marker)
"

[sub_resource type="BoxShape3D" id="BoxShape3D_eeskg"]
size = Vector3(0.37695313, 0.2944336, 0.38549805)

[sub_resource type="Shader" id="Shader_tipk1"]
code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, cull_back;

// --- BASE COLOR ---
uniform vec4 albedo : source_color = vec4(0.55, 0.45, 0.3, 1.0); // Dusty ochre/rocky brown
uniform sampler2D texture_albedo : source_color, filter_linear_mipmap, repeat_enable;

// --- SMART POSTERIZATION (THE ROCKY CRUNCH) ---
uniform bool use_posterization = true;
uniform float color_steps : hint_range(1.0, 16.0, 1.0) = 3.0; 
uniform float black_level_lift : hint_range(0.0, 1.0, 0.01) = 0.15; 

// --- EMISSION (MAGIC VEINS / CRYSTALS) ---
uniform vec4 emission_color : source_color = vec4(1.0, 0.7, 0.1, 1.0); // Amber/Gold geo glow
uniform sampler2D texture_emission : source_color, hint_default_black, filter_linear_mipmap, repeat_enable;
uniform float emission_energy : hint_range(0.0, 16.0, 0.1) = 2.0;

// --- CEL SHADING SHADOWS ---
uniform vec4 shadow_color : source_color = vec4(0.25, 0.18, 0.15, 1.0); // Deep, heavy earth
uniform float shadow_threshold : hint_range(-1.0, 1.0, 0.01) = 0.0;
uniform float shadow_softness : hint_range(0.0, 1.0, 0.01) = 0.01; 

// --- GEO CRYSTAL GLINT (SPECULAR) ---
uniform vec4 specular_color : source_color = vec4(0.9, 0.8, 0.5, 1.0); 
uniform float specular_threshold : hint_range(0.0, 1.0, 0.01) = 0.96; 
uniform float specular_softness : hint_range(0.0, 1.0, 0.01) = 0.005; 

uniform vec3 uv1_scale = vec3(1.0);
uniform vec3 uv1_offset = vec3(0.0);

void vertex() {
    UV = UV * uv1_scale.xy + uv1_offset.xy;
}

void fragment() {
    vec2 base_uv = UV;
    
    vec4 albedo_tex = texture(texture_albedo, base_uv);
    vec3 final_color = albedo_tex.rgb;

    // --- APPLY SMART POSTERIZATION ---
    if (use_posterization) {
        final_color = final_color + vec3(black_level_lift) * (1.0 - final_color);
        float luminance = dot(final_color, vec3(0.299, 0.587, 0.114));
        
        float stepped_luminance = floor(luminance * color_steps) / color_steps;
        stepped_luminance = max(stepped_luminance, 0.1); 
        
        final_color = final_color * (stepped_luminance / max(luminance, 0.0001));
    }

    ALBEDO = albedo.rgb * final_color;
    
    // --- EMISSION CALCULATION ---
    // Sample the black-and-white mask/texture to see where the glow should be
    vec3 emission_tex = texture(texture_emission, base_uv).rgb;
    
    // Multiply by your chosen color and the energy slider
    EMISSION = (emission_color.rgb * emission_tex) * emission_energy;
}

void light() {
    // 1. Toon Diffuse (Base Lighting)
    float NdotL = dot(NORMAL, LIGHT);

    // Hard cut for the rocky shadow
    float light_intensity = smoothstep(shadow_threshold - shadow_softness, shadow_threshold + shadow_softness, NdotL);
    
    // Fix dithered cast shadows
    float toon_attenuation = step(0.5, ATTENUATION);
    float final_light = light_intensity * toon_attenuation;

    vec3 diffuse = mix(shadow_color.rgb * ALBEDO, ALBEDO, final_light);

    // 2. Crystal Specular Glint
    vec3 half_vector = normalize(VIEW + LIGHT);
    float NdotH = dot(NORMAL, half_vector);
    
    float spec_intensity = smoothstep(specular_threshold - specular_softness, specular_threshold + specular_softness, NdotH);
    spec_intensity *= final_light; // Ensure the glint only appears in lit areas

    // 3. Output
    DIFFUSE_LIGHT += diffuse * LIGHT_COLOR;
    SPECULAR_LIGHT += spec_intensity * specular_color.rgb * LIGHT_COLOR;
}"

