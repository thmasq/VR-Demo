[sub_resource type="Shader" id="Shader_50oqk"]
code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, cull_back;

// --- BASE COLOR ---
uniform vec4 albedo : source_color = vec4(1.0, 0.4, 0.0, 1.0);
uniform sampler2D texture_albedo : source_color, filter_nearest, repeat_enable;

// --- CEL SHADING SHADOWS ---
uniform vec4 shadow_color : source_color = vec4(0.6, 0.0, 0.0, 1.0);
uniform float shadow_threshold : hint_range(-1.0, 1.0, 0.01) = 0.0;
uniform float shadow_softness : hint_range(0.0, 1.0, 0.01) = 0.01;

// --- SLIME SHINE (SPECULAR) ---
uniform vec4 specular_color : source_color = vec4(1.0, 0.9, 0.5, 1.0);
uniform float specular_threshold : hint_range(0.0, 1.0, 0.01) = 0.95;
uniform float specular_softness : hint_range(0.0, 1.0, 0.01) = 0.01;

// --- EMISSION (FIRE GLOW) ---
uniform vec4 emission : source_color = vec4(1.0, 0.8, 0.0, 1.0);
uniform sampler2D texture_emission : source_color, hint_default_black, filter_linear_mipmap, repeat_enable;
uniform float emission_energy : hint_range(0.0, 16.0, 0.1) = 2.0;

// --- TOON RIM GLOW ---
// This makes the outer edges of the slime glow brightly!
uniform float rim_threshold : hint_range(0.0, 1.0, 0.01) = 0.65;
uniform float rim_softness : hint_range(0.0, 1.0, 0.01) = 0.05;

uniform vec3 uv1_scale = vec3(1.0);
uniform vec3 uv1_offset = vec3(0.0);

void vertex() {
    UV = UV * uv1_scale.xy + uv1_offset.xy;
}

void fragment() {
    vec2 base_uv = UV;

    vec4 albedo_tex = texture(texture_albedo, base_uv);
    ALBEDO = albedo.rgb * albedo_tex.rgb;
    
    // --- TOON RIM LIGHT (FRESNEL) ---
    // Calculate the angle between the camera (VIEW) and the surface (NORMAL)
    // Edges facing away from the camera approach 1.0
    float fresnel = 1.0 - dot(VIEW, NORMAL);
    
    // Create a hard cartoon cut for the rim outline
    float toon_rim = smoothstep(rim_threshold - rim_softness, rim_threshold + rim_softness, fresnel);

    // --- EMISSION ---
    vec3 emission_tex = texture(texture_emission, base_uv).rgb;
    
    // Combine base emission, the texture, and our new toon rim light
    // We multiply the rim by the emission color so the glowing edges match the fire
    vec3 final_emission = (emission.rgb + emission_tex + (toon_rim * emission.rgb)) * emission_energy;
    
    EMISSION = final_emission;
}

void light() {
    // 1. Calculate lighting angle
    float NdotL = dot(NORMAL, LIGHT);

    // 2. Crisp shadow cut
    float light_intensity = smoothstep(shadow_threshold - shadow_softness, shadow_threshold + shadow_softness, NdotL);

    // 3. Mix base color with the shadow color
    // Multiplying the shadow by ALBEDO naturally tints it
    vec3 diffuse = mix(shadow_color.rgb * ALBEDO, ALBEDO, light_intensity);

    // 4. Slime Specular Dot (The \"wet\" shine)
    vec3 half_vector = normalize(VIEW + LIGHT);
    float NdotH = dot(NORMAL, half_vector);
    
    float spec_intensity = smoothstep(specular_threshold - specular_softness, specular_threshold + specular_softness, NdotH);
    spec_intensity *= light_intensity; // Hide shine in the shadows

    // 5. Output
    DIFFUSE_LIGHT += diffuse * LIGHT_COLOR * ATTENUATION;
    SPECULAR_LIGHT += spec_intensity * specular_color.rgb * LIGHT_COLOR * ATTENUATION;
}"

