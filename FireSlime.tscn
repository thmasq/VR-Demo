[sub_resource type="GDScript" id="GDScript_eeskg"]
resource_name = "ContactExplosion.gdscript"
script/source = "@tool
extends XRToolsPickable

signal arrived_at_spot
signal slime_destroyed(spot_index: int, slime_node: RigidBody3D) 

@onready var vfx_explosion = $VFXGroundExplosion

var current_spot_index: int = -1 

var jump_tween_h: Tween
var jump_tween_v: Tween

func _ready():
	super._ready() 
	
	contact_monitor = true
	max_contacts_reported = 1
	
	body_entered.connect(_on_body_entered)
	
	if has_signal(\"picked_up\"):
		picked_up.connect(_on_picked_up)
	if has_signal(\"dropped\"):
		dropped.connect(_on_dropped)

func _on_picked_up(_pickable):
	if jump_tween_h and jump_tween_h.is_valid():
		jump_tween_h.kill()
	if jump_tween_v and jump_tween_v.is_valid():
		jump_tween_v.kill()

func _on_dropped(_pickable):
	freeze = false

func _on_body_entered(body: Node):
	if body.is_in_group(\"outside_floor\"):
		explode()

func explode():
	body_entered.disconnect(_on_body_entered)
	
	if vfx_explosion:
		vfx_explosion.reparent(get_tree().current_scene)
		
		var anim_player = vfx_explosion.get_node_or_null(\"AnimationPlayer\")
		if anim_player:
			anim_player.play(\"main\") 
		
		get_tree().create_timer(3.0).timeout.connect(vfx_explosion.queue_free)
		
	slime_destroyed.emit(current_spot_index, self)
	
	call_deferred(\"queue_free\") 

func jump_to(target_pos: Vector3, spot_index: int, duration: float = 0.5):
	current_spot_index = spot_index
	
	freeze_mode = RigidBody3D.FREEZE_MODE_KINEMATIC
	freeze = true
	
	if not is_inside_tree(): return
	await get_tree().physics_frame
	if not is_inside_tree(): return 
	
	var space_state = get_world_3d().direct_space_state
	var ray_start = Vector3(target_pos.x, target_pos.y + 2.0, target_pos.z)
	var ray_end = Vector3(target_pos.x, target_pos.y - 2.0, target_pos.z)
	
	var query = PhysicsRayQueryParameters3D.create(ray_start, ray_end)
	var result = space_state.intersect_ray(query)
	
	var floor_y = target_pos.y
	if result:
		floor_y = result.position.y
		
	var drop_y = floor_y + 0.15 
	
	jump_tween_h = create_tween()
	jump_tween_h.set_parallel(true)
	jump_tween_h.tween_property(self, \"global_position:x\", target_pos.x, duration)
	jump_tween_h.tween_property(self, \"global_position:z\", target_pos.z, duration)
	
	var target_rot_y = rotation_degrees.y - 180.0
	jump_tween_h.tween_property(self, \"rotation_degrees:y\", target_rot_y, duration)
	
	var peak_y = max(global_position.y, floor_y) + 0.8
	jump_tween_v = create_tween()
	
	jump_tween_v.tween_property(self, \"global_position:y\", peak_y, duration / 2.0).set_ease(Tween.EASE_OUT).set_trans(Tween.TRANS_QUAD)
	jump_tween_v.tween_property(self, \"global_position:y\", drop_y, duration / 2.0).set_ease(Tween.EASE_IN).set_trans(Tween.TRANS_QUAD)
	
	await jump_tween_v.finished
	
	if not is_inside_tree() or is_queued_for_deletion():
		return
	
	linear_velocity = Vector3.ZERO
	angular_velocity = Vector3.ZERO
	
	freeze = false
	arrived_at_spot.emit()
"

