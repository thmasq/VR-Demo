[sub_resource type="Shader" id="Shader_4c57u"]
code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, cull_back;

// --- BASE COLOR ---
uniform vec4 albedo : source_color = vec4(0.8, 0.65, 0.45, 1.0); // Warm Kraft Paper Tan
uniform sampler2D texture_albedo : source_color, filter_linear_mipmap, repeat_enable;

// NEW: This threshold forces the material into the Opaque pipeline, fixing your depth bug!
uniform float alpha_scissor_threshold : hint_range(0.0, 1.0) = 0.5;

// --- CEL SHADING SHADOWS ---
uniform vec4 shadow_color : source_color = vec4(0.5, 0.35, 0.2, 1.0); // Darker, warm brown
uniform float shadow_threshold : hint_range(-1.0, 1.0, 0.01) = 0.0;
uniform float shadow_softness : hint_range(0.0, 1.0, 0.01) = 0.05; 

// --- AMBIENT OCCLUSION ---
uniform sampler2D texture_ao : hint_default_white, filter_linear_mipmap, repeat_enable;
uniform float ao_strength : hint_range(0.0, 1.0, 0.01) = 1.0;

uniform vec3 uv1_scale = vec3(1.0);
uniform vec3 uv1_offset = vec3(0.0);

// Varying to pass AO data from fragment to light function
varying float toon_ao;

void vertex() {
    UV = UV * uv1_scale.xy + uv1_offset.xy;
}

void fragment() {
    vec2 base_uv = UV;
    vec4 albedo_tex = texture(texture_albedo, base_uv);
    
    ALBEDO = albedo.rgb * albedo_tex.rgb;
    
    // --- THE DEPTH FIX ---
    ALPHA = albedo.a * albedo_tex.a;
    ALPHA_SCISSOR_THRESHOLD = alpha_scissor_threshold; 
    // (Note: If your cardboard never has holes, you can completely delete 
    // the ALPHA and ALPHA_SCISSOR_THRESHOLD lines to make it purely opaque)

    // --- THE AO SETUP ---
    toon_ao = mix(1.0, texture(texture_ao, base_uv).r, ao_strength);
}

void light() {
    float NdotL = dot(NORMAL, LIGHT);

    // --- APPLY THE AO HACK ---
    // Multiply light direction by AO to force crevices into the stylized shadow
    float adjusted_light = NdotL * toon_ao;

    float light_intensity = smoothstep(shadow_threshold - shadow_softness, shadow_threshold + shadow_softness, adjusted_light);

    vec3 diffuse = mix(shadow_color.rgb * ALBEDO, ALBEDO, light_intensity);

    DIFFUSE_LIGHT += diffuse * LIGHT_COLOR * ATTENUATION;
}"

