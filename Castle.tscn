[sub_resource type="Shader" id="Shader_f0bkf"]
code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, cull_back;

// --- BASE COLOR ---
uniform vec4 albedo : source_color = vec4(0.3, 0.3, 0.35, 1.0); // Dark iron gray
uniform sampler2D texture_albedo : source_color, filter_linear_mipmap, repeat_enable;

// --- SMART POSTERIZATION ---
uniform bool use_posterization = true;
uniform float color_steps : hint_range(1.0, 16.0, 1.0) = 3.0; 
uniform float black_level_lift : hint_range(0.0, 1.0, 0.01) = 0.1; 

// --- NORMAL MAP ---
uniform sampler2D texture_normal : hint_normal, filter_linear_mipmap, repeat_enable;
uniform float normal_scale : hint_range(-16.0, 16.0) = 1.0;

// --- CEL SHADING SHADOWS ---
uniform vec4 shadow_color : source_color = vec4(0.1, 0.1, 0.15, 1.0); // Almost black/navy
uniform float shadow_threshold : hint_range(-1.0, 1.0, 0.01) = 0.0;
uniform float shadow_softness : hint_range(0.0, 1.0, 0.01) = 0.01; 

// --- TOON METAL GLINT (SPECULAR) ---
uniform vec4 specular_color : source_color = vec4(0.9, 0.9, 0.95, 1.0); // Bright, sharp white
uniform float specular_threshold : hint_range(0.0, 1.0, 0.01) = 0.95; // Very high for a tiny glint
uniform float specular_softness : hint_range(0.0, 1.0, 0.01) = 0.01;

uniform vec3 uv1_scale = vec3(1.0);
uniform vec3 uv1_offset = vec3(0.0);

void vertex() {
    UV = UV * uv1_scale.xy + uv1_offset.xy;
}

void fragment() {
    vec2 base_uv = UV;
    
    vec4 albedo_tex = texture(texture_albedo, base_uv);
    vec3 final_color = albedo_tex.rgb;

    // Apply Smart Posterization to chunk up the rust/wear on the bolts
    if (use_posterization) {
        final_color = final_color + vec3(black_level_lift) * (1.0 - final_color);
        float luminance = dot(final_color, vec3(0.299, 0.587, 0.114));
        float stepped_luminance = floor(luminance * color_steps) / color_steps;
        stepped_luminance = max(stepped_luminance, 0.1);
        final_color = final_color * (stepped_luminance / max(luminance, 0.0001));
    }

    ALBEDO = albedo.rgb * final_color;
    
    // Normal Map applied so the specular glints catch the hammered dents
    NORMAL_MAP = texture(texture_normal, base_uv).rgb;
    NORMAL_MAP_DEPTH = normal_scale;
}

void light() {
    // 1. Toon Diffuse (Base Lighting)
    float NdotL = dot(NORMAL, LIGHT);
    float light_intensity = smoothstep(shadow_threshold - shadow_softness, shadow_threshold + shadow_softness, NdotL);
    float toon_attenuation = step(0.5, ATTENUATION);
    float final_light = light_intensity * toon_attenuation;

    vec3 diffuse = mix(shadow_color.rgb * ALBEDO, ALBEDO, final_light);

    // 2. Toon Specular (The Metal Glint)
    vec3 half_vector = normalize(VIEW + LIGHT);
    float NdotH = dot(NORMAL, half_vector);
    
    float spec_intensity = smoothstep(specular_threshold - specular_softness, specular_threshold + specular_softness, NdotH);
    
    // Ensure the glint only appears where the light actually hits
    spec_intensity *= final_light; 

    // 3. Output
    DIFFUSE_LIGHT += diffuse * LIGHT_COLOR;
    SPECULAR_LIGHT += spec_intensity * specular_color.rgb * LIGHT_COLOR;
}"

