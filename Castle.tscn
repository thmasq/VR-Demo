[sub_resource type="GDScript" id="GDScript_5bpw4"]
resource_name = "SlimeSpawner.gdscript"
script/source = "extends Node3D

@export var slime_scene: PackedScene
@export var spawn_spots: Array[Marker3D] 
@export var max_global_slimes: int = 5 # Global limit to prevent hoarding

@onready var hinge = $Hinge
@onready var elevator = $Elevator

const HINGE_CLOSED = 0.0
const HINGE_OPEN = 90.0 
const ELEVATOR_BOTTOM = -0.373
const ELEVATOR_TOP = 0.0

var spots_occupied: Array[bool] = []
var is_spawning = false
var waiting_slime: RigidBody3D = null

# NEW: Track slimes currently in the scene
var global_slime_count: int = 0 

func _ready():
	spots_occupied.resize(spawn_spots.size())
	spots_occupied.fill(false)
	
	hinge.rotation_degrees.y = HINGE_CLOSED 
	elevator.position.y = ELEVATOR_BOTTOM
	
	var timer = get_node_or_null(\"SpawnTimer\")
	if timer:
		timer.timeout.connect(attempt_spawn)

func attempt_spawn():
	if is_spawning:
		return
	
	# 1. NEW: Check global limit before spawning
	if global_slime_count >= max_global_slimes:
		return
	
	var available_spot = get_available_spot()
	
	if available_spot == -1 and waiting_slime != null:
		return
		
	spawn_sequence(available_spot)

func get_available_spot() -> int:
	for i in range(spots_occupied.size()):
		if not spots_occupied[i]:
			return i
	return -1

func spawn_sequence(target_spot: int):
	is_spawning = true
	
	# Increment global count the moment it spawns
	global_slime_count += 1
	
	var slime = slime_scene.instantiate()
	add_child(slime)
	
	slime.position = Vector3(elevator.position.x, elevator.position.y + 0.1, elevator.position.z)
	
	slime.freeze_mode = RigidBody3D.FREEZE_MODE_KINEMATIC
	slime.freeze = true
	
	slime.slime_destroyed.connect(_on_slime_destroyed)
	if slime.has_signal(\"picked_up\"):
		slime.picked_up.connect(func(_pickable): _on_slime_grabbed(slime))
	
	var tween = create_tween()
	tween.tween_property(hinge, \"rotation_degrees:y\", HINGE_OPEN, 0.5)
	await tween.finished
	
	if not is_instance_valid(slime):
		descend_and_close()
		return
	
	tween = create_tween()
	tween.set_parallel(true) 
	tween.tween_property(elevator, \"position:y\", ELEVATOR_TOP, 1.0)
	tween.tween_property(slime, \"position:y\", ELEVATOR_TOP + 0.1, 1.0) 
	await tween.finished
	
	if target_spot != -1:
		if not is_instance_valid(slime):
			descend_and_close()
			return
			
		var target_marker = spawn_spots[target_spot]
		spots_occupied[target_spot] = true
		
		slime.jump_to(target_marker.global_position, target_spot)
		
		await get_tree().create_timer(0.6).timeout 
		descend_and_close()
	else:
		waiting_slime = slime
		slime.current_spot_index = -1 
		is_spawning = false 

func descend_and_close():
	var tween = create_tween()
	tween.tween_property(elevator, \"position:y\", ELEVATOR_BOTTOM, 1.0)
	await tween.finished
	
	tween = create_tween()
	tween.tween_property(hinge, \"rotation_degrees:y\", HINGE_CLOSED, 0.5)
	await tween.finished
	
	is_spawning = false

# --- NEW BEHAVIORS ---

func _on_slime_grabbed(slime: RigidBody3D):
	# If the player grabbed the waiting slime straight off the elevator
	if slime == waiting_slime:
		waiting_slime = null
		descend_and_close()
		slime.current_spot_index = -2 # Mark as roaming
		return
		
	# If the player grabbed a slime from a spot
	if slime.current_spot_index >= 0:
		var spot = slime.current_spot_index
		slime.current_spot_index = -2 # Mark as roaming
		free_spot(spot) # Freeing the spot triggers the waiting slime to jump!

func _on_slime_destroyed(spot_index: int, slime: RigidBody3D):
	call_deferred(\"decrement_global_count\")
	
	if slime == waiting_slime:
		waiting_slime = null
		call_deferred(\"descend_and_close\")
		return

	if spot_index >= 0:
		call_deferred(\"free_spot\", spot_index)

func decrement_global_count():
	global_slime_count -= 1
	if global_slime_count < 0:
		global_slime_count = 0

func free_spot(spot_index: int):
	if spot_index >= 0 and spot_index < spots_occupied.size():
		spots_occupied[spot_index] = false
		
		if waiting_slime != null and is_instance_valid(waiting_slime) and not waiting_slime.is_queued_for_deletion():
			var slime_to_move = waiting_slime
			waiting_slime = null 
			
			var target_marker = spawn_spots[spot_index]
			spots_occupied[spot_index] = true
			
			slime_to_move.jump_to(target_marker.global_position, spot_index)
			descend_and_close()
"

