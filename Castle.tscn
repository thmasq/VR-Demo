[sub_resource type="Shader" id="Shader_ucxtu"]
code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, cull_back;

// --- BASE COLOR ---
uniform vec4 albedo : source_color = vec4(1.0, 1.0, 1.0, 1.0);
uniform sampler2D texture_albedo : source_color, filter_linear_mipmap, repeat_enable;

// --- SMART POSTERIZATION ---
uniform bool use_posterization = true;
uniform float color_steps : hint_range(1.0, 16.0, 1.0) = 3.0;
// NEW: Lifts pure black pixels so they can be colorized and posterized
uniform float black_level_lift : hint_range(0.0, 1.0, 0.01) = 0.2; 

// --- NORMAL MAP ---
uniform sampler2D texture_normal : hint_normal, filter_linear_mipmap, repeat_enable;
uniform float normal_scale : hint_range(-16.0, 16.0) = 1.0;

// --- AMBIENT OCCLUSION ---
uniform sampler2D texture_ao : hint_default_white, filter_linear_mipmap, repeat_enable;
uniform float ao_strength : hint_range(0.0, 1.0, 0.01) = 1.0;

// --- CEL SHADING SHADOWS ---
uniform vec4 shadow_color : source_color = vec4(0.2, 0.2, 0.25, 1.0); // Cool, dark slate
uniform float shadow_threshold : hint_range(-1.0, 1.0, 0.01) = 0.0;
uniform float shadow_softness : hint_range(0.0, 1.0, 0.01) = 0.01; 

uniform vec3 uv1_scale = vec3(1.0);
uniform vec3 uv1_offset = vec3(0.0);

varying float toon_ao;

void vertex() {
    UV = UV * uv1_scale.xy + uv1_offset.xy;
}

void fragment() {
    vec2 base_uv = UV;
    
    // Sample the raw photo texture
    vec4 albedo_tex = texture(texture_albedo, base_uv);
    vec3 final_color = albedo_tex.rgb;

    // --- APPLY SMART POSTERIZATION ---
    if (use_posterization) {
        // 1. LIFT THE BLACKS FIRST. 
        // You can't multiply pure black (0,0,0) to make it brighter. 
        // We use a screen blend to lift dark areas without blowing out the whites.
        final_color = final_color + vec3(black_level_lift) * (1.0 - final_color);

        // 2. Find the actual brightness of the pixel
        float luminance = dot(final_color, vec3(0.299, 0.587, 0.114));
        
        // 3. Snap the brightness into discrete steps (e.g., 3 flat bands)
        float stepped_luminance = floor(luminance * color_steps) / color_steps;
        
        // 4. Prevent the lowest step from crushing back into pure black
        stepped_luminance = max(stepped_luminance, 0.1);
        
        // 5. Apply the stepped brightness back to the original color.
        final_color = final_color * (stepped_luminance / max(luminance, 0.0001));
    }

    ALBEDO = albedo.rgb * final_color;
    // (Opaque wall: ALPHA is intentionally removed here to protect the depth buffer)

    // --- NORMAL MAP ---
    NORMAL_MAP = texture(texture_normal, base_uv).rgb;
    NORMAL_MAP_DEPTH = normal_scale;

    // --- CAPTURE AO ---
    toon_ao = mix(1.0, texture(texture_ao, base_uv).r, ao_strength);
}

void light() {
    // 1. Calculate lighting angle (Godot automatically factors in your Normal Map here!)
    float NdotL = dot(NORMAL, LIGHT);

    // 2. Crisp shadow cut
    float light_intensity = smoothstep(shadow_threshold - shadow_softness, shadow_threshold + shadow_softness, NdotL);

    // 3. Fix dithered cast shadows
    float toon_attenuation = step(0.5, ATTENUATION);

    // 4. Combine lighting with Ambient Occlusion crevices
    float final_light = light_intensity * toon_attenuation * toon_ao;

    // 5. Mix base color with stylized shadow color
    vec3 diffuse = mix(shadow_color.rgb * ALBEDO, ALBEDO, final_light);

    // 6. Output
    DIFFUSE_LIGHT += diffuse * LIGHT_COLOR;
}"

